// ============================================================
//  Prisma Schema — The Teneen (Extended from Clac-Calories)
//  Adds: User, MealLog for mobile app layer
//  Preserves: Restaurant, CachedMenuItem, CachedAddOn, Company
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Existing Models (Preserved) ─────────────────────────────

model Restaurant {
  id        String           @id @default(uuid())
  name      String           @unique
  category  String
  rating    Float            @default(4.6)
  items     CachedMenuItem[]
  addOns    CachedAddOn[]
  createdAt DateTime         @default(now())
}

model CachedMenuItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  itemName     String

  caloriesMin  Int
  caloriesMax  Int
  proteinMin   Int
  proteinMax   Int
  carbsMin     Int
  carbsMax     Int
  fatsMin      Int
  fatsMax      Int

  createdAt    DateTime   @default(now())

  @@unique([restaurantId, itemName])
}

model CachedAddOn {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  addOnName    String
  calories     Int
  protein      Int
  carbs        Int
  fats         Int

  createdAt    DateTime   @default(now())

  @@unique([restaurantId, addOnName])
}

model Company {
  id        String   @id @default(uuid())
  name      String
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apiKey])
}

// ── New Models for The Teneen Mobile App ────────────────────

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  passwordHash      String
  dailyCalorieGoal  Int       @default(2000)
  proteinGoal       Int       @default(150)
  carbsGoal         Int       @default(200)
  fatsGoal          Int       @default(65)
  isActive          Boolean   @default(true)
  mealLogs          MealLog[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
}

model MealLog {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantName       String
  mealName             String
  imageUrl             String?

  calories             Float
  protein              Float
  carbs                Float
  fats                 Float

  ingredientsBreakdown Json     // Array of { ingredient: string, estimatedWeightGrams: number }
  rawAiResponse        Json?    // Full Gemini response stored for auditing

  source               String   @default("text") // "text" | "image"
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId])
}
