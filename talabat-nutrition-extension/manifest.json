{
  "manifest_version": 3,
  "name": "Nutrition Calculator — Universal",
  "version": "1.1.0",
  "description": "Real-time macro calculator for Talabat, Mrsool, Elmenus, HungerStation and more",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.elmenus.com/*",
    "https://*.talabat.com/*",
    "https://*.mrsool.co/*",
    "https://*.mrsool.com/*",
    "https://*.hungerstation.com/*",
    "https://*.jahez.net/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.elmenus.com/*",
        "https://*.talabat.com/*",
        "https://*.mrsool.co/*",
        "https://*.mrsool.com/*",
        "https://*.hungerstation.com/*",
        "https://*.jahez.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nutrition Calculator"
  }
}
