# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/calc_calories?schema=public"

# ── Gemini AI ──────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"
# Optional: gemini-2.0-flash-lite (default), gemini-1.5-pro, gemini-2.5-flash
# GEMINI_MODEL="gemini-1.5-pro"

# Set to "true" to use mock AI responses (no Gemini API calls)
# GEMINI_MOCK=true

# ── Redis ──────────────────────────────────────────────────────────
# Redis connection URL (e.g. redis://localhost:6379)
REDIS_URL="redis://localhost:6379"

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT Auth (Mobile API v1) ───────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-secure-random-64-char-string-in-production"
JWT_EXPIRES_IN="7d"

# ── Upload Settings ────────────────────────────────────────────────
# Maximum size of uploaded meal screenshots in MB
UPLOAD_MAX_SIZE_MB=10

# ── Rate Limiting ──────────────────────────────────────────────────
# Requests per minute per user for the /analyze endpoint
RATE_LIMIT_RPM=30

# ── Local Ollama (Local LLM Inference) ────────────────────────────
# Required for POST /api/v1/meals/scan-local (Local Llama image scan)
#
# 1. Install Ollama: https://ollama.com/download
# 2. Pull a vision model: ollama pull llava
#    (alternatives: llava:13b, llama3.2-vision, moondream)
# 3. Pull a text model:   ollama pull llama3
#
# Base URL of your local Ollama server
OLLAMA_BASE_URL="http://127.0.0.1:11434"
#
# Text-only model used by the existing /meals/analyze text endpoint
OLLAMA_MODEL="llama3"
#
# Vision model used by the NEW /meals/scan-local image endpoint
# Must support multimodal image input (llava, llama3.2-vision, moondream)
OLLAMA_VISION_MODEL="llava"
#
# Set AI_PROVIDER=ollama to use local Ollama for text analysis instead of Gemini
# AI_PROVIDER="ollama"
